# ── Gateway (downstream) ───────────────────────────────────────────────────
# Port the gateway listens on.
PORT=3000
# Bind address. Defaults to localhost only for safety. Set to 0.0.0.0 to expose.
HOST=127.0.0.1
# Key(s) downstream OpenAI clients must present (Authorization: Bearer <key>).
# Supports a comma-separated list of accepted keys.
PROXY_API_KEY=changeme-local-key

# ── Upstream (Anthropic) ─────────────────────────────────────────────────────
# Base URL of the Anthropic-compatible upstream.
UPSTREAM_BASE_URL=https://api.anthropic.com
# Upstream auth mode: "api_key" or "oauth".
UPSTREAM_AUTH_MODE=api_key
# Required when UPSTREAM_AUTH_MODE=api_key (sk-ant-api-*).
ANTHROPIC_API_KEY=
# Required when UPSTREAM_AUTH_MODE=oauth (sk-ant-oat-*).
ANTHROPIC_OAUTH_TOKEN=
# Optional refresh token used to auto-refresh the OAuth access token on 401.
ANTHROPIC_OAUTH_REFRESH_TOKEN=

# ── Claude Code emulation ────────────────────────────────────────────────────
# anthropic-version header value.
ANTHROPIC_VERSION=2023-06-01
# Claude Code CLI version used in the user-agent. Bump as the CLI updates.
CLAUDE_CODE_VERSION=2.1.85
# anthropic-beta flags. The oauth flag is added automatically in oauth mode.
ANTHROPIC_BETA=claude-code-20250219
# Force-inject the mandatory Claude Code system prefix (required for non-Haiku in oauth).
INJECT_CLAUDE_CODE_SYSTEM=true

# ── Models ───────────────────────────────────────────────────────────────────
# Fallback model when the client sends an unknown/empty model name.
DEFAULT_MODEL=claude-sonnet-4-6
# JSON string overriding the OpenAI->Anthropic model map (see README §Models).
# MODEL_MAP={"gpt-4o":"claude-sonnet-4-6"}

# ── Behavior ─────────────────────────────────────────────────────────────────
# Upstream request timeout in milliseconds.
REQUEST_TIMEOUT_MS=300000
# Retries on 429/5xx with exponential backoff.
MAX_RETRIES=2
# Default max_tokens when the client omits it (Anthropic requires max_tokens).
DEFAULT_MAX_TOKENS=4096
# Max request body size in bytes (DoS protection).
MAX_BODY_BYTES=10485760
# Map Anthropic extended-thinking deltas to OpenAI reasoning_content.
EMIT_REASONING_CONTENT=true

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Log request/response bodies (secrets are always masked).
LOG_BODIES=false
